<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BambuDry.App.ViewModels"
        x:Class="BambuDry.App.Views.PrinterSetupWindow"
        x:DataType="vm:AppViewModel"
        Width="440" Height="380"
        Title="Add your Bambu printer"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Manual">
    <Grid Margin="16" RowDefinitions="Auto,Auto,*,Auto">
        <TextBlock Grid.Row="0" Text="Add your Bambu printer" FontSize="16" FontWeight="SemiBold"/>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,4,0,12" Opacity="0.8" FontSize="12"
                   Text="On the printer touchscreen: Settings → WLAN. The Access Code is on the same screen (8 characters)."/>

        <Border Grid.Row="2" CornerRadius="6" Padding="10" Margin="0,0,0,12"
                Background="#332E1B" BorderBrush="DarkOrange" BorderThickness="1">
            <TextBlock Foreground="OrangeRed" TextWrapping="Wrap" FontSize="12">
                <Run FontWeight="SemiBold" Text="Enable Developer Mode on the printer"/>
                <LineBreak/>
                <Run Text="Settings → General → Developer Mode. Without it the firmware silently ignores remote drying commands over LAN — humidity will display, but auto-dry won't actually start the heater."/>
            </TextBlock>
        </Border>

        <StackPanel Grid.Row="3" Spacing="8">
            <Grid ColumnDefinitions="120,*">
                <TextBlock Grid.Column="0" Text="Name"        VerticalAlignment="Center"/>
                <TextBox  Grid.Column="1" x:Name="NameField" Text="{Binding Config.PrinterName, Mode=OneTime}"/>
            </Grid>
            <Grid ColumnDefinitions="120,*">
                <TextBlock Grid.Column="0" Text="LAN IP"      VerticalAlignment="Center"/>
                <TextBox  Grid.Column="1" x:Name="IpField"    Text="{Binding Config.LanIp, Mode=OneTime}" Watermark="192.168.x.x"/>
            </Grid>
            <Grid ColumnDefinitions="120,*">
                <TextBlock Grid.Column="0" Text="Serial"      VerticalAlignment="Center"/>
                <TextBox  Grid.Column="1" x:Name="SerialField" Text="{Binding Config.Serial, Mode=OneTime}" Watermark="01S00A2B…"/>
            </Grid>
            <Grid ColumnDefinitions="120,*">
                <TextBlock Grid.Column="0" Text="Access Code" VerticalAlignment="Center"/>
                <TextBox  Grid.Column="1" x:Name="CodeField"  PasswordChar="•" Watermark="8 characters"/>
            </Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0" Spacing="8">
                <Button Content="Cancel" Click="OnCancel"/>
                <Button Content="Save &amp; Connect" Click="OnSave" Classes="accent"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
